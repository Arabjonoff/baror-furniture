# Muhit sozlamalari namunasi.
# Serverda bu faylni `.env` deb nusxalang va qiymatlarni to'ldiring.
# `.env` fayli git'ga yuklanmaydi (maxfiy).

# Django maxfiy kaliti — serverda albatta yangi tasodifiy qiymat qo'ying:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

# Ishlab chiqarishda (production) DEBUG=False bo'lishi SHART
DEBUG=True

# Vergul bilan ajratilgan ruxsat etilgan hostlar
# Production: barormebel.uz,www.barormebel.uz
ALLOWED_HOSTS=127.0.0.1,localhost

# CSRF ishonchli manbalar (production HTTPS domenlari)
CSRF_TRUSTED_ORIGINS=https://barormebel.uz,https://www.barormebel.uz

# SQLite ishlatilsinmi (True) yoki PostgreSQL (False)
# Production: False
USE_SQLITE=True

# PostgreSQL sozlamalari (USE_SQLITE=False bo'lganda)
DB_NAME=barormebel
DB_USER=barormebel
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Ixtiyoriy: HTTP -> HTTPS yo'naltirishni Django bajarishi (odatda nginx bajaradi)
# SECURE_SSL_REDIRECT=False
